# Database (SQLite for local/demo. For production swap to PostgreSQL, see README)
DATABASE_URL="file:./dev.db"

# Server
PORT=4000
NODE_ENV=development

# Auth
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# Frontend origin for CORS
FRONTEND_URL="http://localhost:3000"

# Ministry hotline shown in SMS / UI
MINISTRY_HOTLINE="16135"

# Twilio (optional - only needed for real SMS. Leave blank to use the in-app SMS simulator)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
